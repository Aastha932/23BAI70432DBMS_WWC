WITH july_users AS (
    SELECT DISTINCT user_id
    FROM user_actions
    WHERE EXTRACT(YEAR FROM event_date) = 2022
      AND EXTRACT(MONTH FROM event_date) = 7
),
june_users AS (
    SELECT DISTINCT user_id
    FROM user_actions
    WHERE EXTRACT(YEAR FROM event_date) = 2022
      AND EXTRACT(MONTH FROM event_date) = 6
)

SELECT
    7 AS month,
    COUNT(DISTINCT j.user_id) AS monthly_active_users
FROM july_users j
JOIN june_users p
    ON j.user_id = p.user_id;
